// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id               String       @id @default(uuid())
  name             String
  email            String       @unique
  passwordHash     String
  role             Role         @default(STUDENT)
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  logs             AuditLog[]
  timetable        Timetable[]
  student          Student?
  attendanceMarked Attendance[]
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String // Who did it?
  action    String // CREATE, UPDATE, DELETE
  entity    String // Which table? (e.g., "Grade", "Fee")
  entityId  String // The ID of the record changed
  oldData   Json? // State before change
  newData   Json? // State after change
  ipAddress String? // From which IP?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AcademicYear {
  id        String   @id @default(uuid())
  name      String // e.g., "2025-2026"
  isCurrent Boolean  @default(false)
  classes   Class[]
  createdAt DateTime @default(now())
}

model Class {
  id             String       @id @default(uuid())
  name           String // e.g., "Grade 10"
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  sections       Section[]
  subjects       Subject[] // Subjects assigned to this grade level
}

model Section {
  id        String      @id @default(uuid())
  name      String // e.g., "Section A"
  classId   String
  class     Class       @relation(fields: [classId], references: [id])
  timetable Timetable[]
  students  Student[]
}

model Subject {
  id        String      @id @default(uuid())
  name      String // e.g., "Mathematics"
  code      String // e.g., "MATH101"
  classId   String
  class     Class       @relation(fields: [classId], references: [id])
  timetable Timetable[]
}

model Timetable {
  id        String    @id @default(uuid())
  day       DayOfWeek
  period    Int // e.g., 1, 2, 3...
  startTime String // e.g., "08:00"
  endTime   String // e.g., "08:45"

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  teacherId String
  teacher   User   @relation(fields: [teacherId], references: [id])

  @@unique([sectionId, day, period]) // Prevents two subjects in one section at the same time
  @@unique([teacherId, day, period]) // Prevents a teacher being in two places at once
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model Student {
  id              String       @id @default(uuid())
  admissionNumber String       @unique
  rollNumber      String?
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  gender          String
  address         String?
  phoneNumber     String?
  userId          String?      @unique // Link to their login account
  user            User?        @relation(fields: [userId], references: [id])
  sectionId       String
  section         Section      @relation(fields: [sectionId], references: [id])
  parents         Parent[]
  attendance      Attendance[]
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Parent {
  id             String    @id @default(uuid())
  fatherName     String?
  fatherPhone    String?
  motherName     String?
  motherPhone    String?
  emergencyPhone String
  primaryContact String    @default("FATHER")
  email          String?
  occupation     String?
  address        String?
  students       Student[]
  createdAt      DateTime  @default(now())
}

model Attendance {
  id     String           @id @default(uuid())
  date   DateTime         @default(now())
  status AttendanceStatus

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  markedById String
  markedBy   User   @relation(fields: [markedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}
